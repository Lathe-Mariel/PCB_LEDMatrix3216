//Pmod USB A side
IO_LOC "joystick_cs2" G5;
IO_PORT "joystick_cs2" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_mosi2" G8;
IO_PORT "joystick_mosi2" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_clk2" J5;
IO_PORT "joystick_clk2" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_cs" F5;
IO_PORT "joystick_cs" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_mosi" G7;
IO_PORT "joystick_mosi" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_clk" H5;
IO_PORT "joystick_clk" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "joystick_miso2" H7;
IO_PORT "joystick_miso2" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=OFF BANK_VCCIO=3.3;
IO_LOC "joystick_miso" H8;
IO_PORT "joystick_miso" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=OFF BANK_VCCIO=3.3;

IO_LOC "USER_KEY" H11;
IO_PORT "USER_KEY" PULL_MODE=DOWN DRIVE=OFF BANK_VCCIO=3.3;
IO_LOC "USER_KEY2" H10;
IO_PORT "USER_KEY2" PULL_MODE=DOWN DRIVE=OFF BANK_VCCIO=3.3;
IO_LOC "clk" E2;
IO_PORT "clk" PULL_MODE=NONE DRIVE=OFF BANK_VCCIO=3.3;
