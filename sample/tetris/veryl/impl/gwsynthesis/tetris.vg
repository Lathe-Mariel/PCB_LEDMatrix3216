`pragma protect end_protected
module gw_gao (
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  clk_d,
  SIN2_d,
  SIN3_d,
  LATCH_d,
  LED_CLK_d,
  STROBE__d,
  SIN1_d,
  tdo_pad_o
)
;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
input clk_d;
input SIN2_d;
input SIN3_d;
input LATCH_d;
input LED_CLK_d;
input STROBE__d;
input SIN1_d;
output tdo_pad_o;
wire tms_i_c;
wire tck_i_c;
wire tdi_i_c;
wire tdo_o_c;
wire gao_jtag_tdi;
wire gao_jtag_reset;
wire run_test_idle_er1;
wire run_test_idle_er2;
wire shift_dr_capture_dr;
wire pause_dr;
wire enable_er1;
wire enable_er2;
wire tdo_er1;
wire n12_6;
wire [5:0] control0;
wire [4:2] control0_0;
wire [3:0] module_id_reg;
wire [7:7] control0_1;
wire VCC;
wire GND;
  IBUF tms_ibuf (
    .O(tms_i_c),
    .I(tms_pad_i) 
);
  IBUF tck_ibuf (
    .O(tck_i_c),
    .I(tck_pad_i) 
);
  IBUF tdi_ibuf (
    .O(tdi_i_c),
    .I(tdi_pad_i) 
);
  OBUF tdo_obuf (
    .O(tdo_pad_o),
    .I(tdo_o_c) 
);
//black box: GW_JTAG u_gw_jtag
  GW_JTAG u_gw_jtag (
    .tck_pad_i(tck_i_c),
    .tms_pad_i(tms_i_c),
    .tdi_pad_i(tdi_i_c),
    .tdo_er1_i(tdo_er1),
    .tdo_er2_i(GND),
    .tdo_pad_o(tdo_o_c),
    .tck_o(control0[0]),
    .tdi_o(gao_jtag_tdi),
    .test_logic_reset_o(gao_jtag_reset),
    .run_test_idle_er1_o(run_test_idle_er1),
    .run_test_idle_er2_o(run_test_idle_er2),
    .shift_dr_capture_dr_o(shift_dr_capture_dr),
    .pause_dr_o(pause_dr),
    .update_dr_o(control0[5]),
    .enable_er1_o(enable_er1),
    .enable_er2_o(enable_er2) 
);
  gw_con_top u_icon_top (
    .shift_dr_capture_dr(shift_dr_capture_dr),
